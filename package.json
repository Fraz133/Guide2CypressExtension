{
  "name": "guide2cypress-vscode",
  "displayName": "Guide2Cypress-VSCode",
  "description": "The VS Code command center for Guide2Cypress.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "publisher": "local",
  "repository": {
    "type": "git",
    "url": "https://example.com/your-repo.git"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Guide2Cypress",
      "properties": {
        "guide2cypress.npxPath": {
          "type": "string",
          "default": "/Users/usear/.nvm/versions/node/v18.20.5/bin/npx",
          "description": "The absolute path to the 'npx' executable. Only change this if the extension cannot find 'npx' automatically from your system's PATH."
        }
      }
    },
    "commands": [
      {
        "command": "guide2cypress.showPanel",
        "title": "Show Guide2Cypress Panel"
      },
      {
        "command": "guide2cypress.startListener",
        "title": "Start G2C Listener"
      },
      {
        "command": "guide2cypress.healTest",
        "title": "Heal G2C Test"
      },
      {
        "command": "guide2cypress.generateA11yReport",
        "title": "Generate Accessibility Report"
      },
      {
        "command": "guide2cypress.runTest",
        "title": "Run G2C Test"
      },
      {
        "command": "guide2cypress.stopListener",
        "title": "Stop G2C Listener"
      },
      {
        "command": "guide2cypress.openProjectFolder",
        "title": "Open Cypress Project Folder"
      },
      {
        "command": "guide2cypress.resetToListener",
        "title": "Reset to Listener"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "guide2cypress-sidebar",
          "title": "Guide2Cypress",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "guide2cypress-sidebar": [
        {
          "id": "guide2cypress.panel",
          "name": "Control Panel",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && npm run copy-assets", 
    "watch": "tsc -watch -p ./",
    "copy-assets": "cpx \"src/webview/**/*.html\" out/webview",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "20.2.5",
    "@types/node-fetch": "^2.6.13",
    "@types/pngjs": "^6.0.5",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "@vscode/test-electron": "^2.3.2",
    "cpx": "^1.5.0",
    "eslint": "^8.41.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "node-fetch": "^2.7.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0"
  }
}
